{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@extractors/*": ["src/extractors/*"],
      "@rules/*":      ["src/rules/*"],
      "@reporters/*":  ["src/reporters/*"],
      "@utils/*":      ["src/utils/*"],
      "@/*":           ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
